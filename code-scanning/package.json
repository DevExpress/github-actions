    "scan:node-versions": "tsx scripts/run.ts validateNodeVersions",
    "scan:pnpm-audit": "tsx scripts/run.ts pnpmAudit",
    "scan": "tsx scripts/run.ts all"
  },
  "devDependencies": {
    "@types/jest": "catalog:",
